        <script><![CDATA[(function executeRule(current, previous) {
    var volunteerSysId = current.getValue('volunteer');
    if (!volunteerSysId) return;
    var projectVal = current.getValue('project') || 'a project';
    var notif = new GlideRecord('x_2048396_ngo_vo_1_notifications');
    notif.initialize();
    notif.setValue('recipient', volunteerSysId);
    notif.setValue('message', 'You have been assigned to the project: ' + projectVal + '.');
    notif.setValue('type', 'assignment');
    notif.setValue('is_read', false);
    notif.setValue('created_on', new GlideDateTime().getValue());
    notif.insert();
})(current, previous);]]></script>
