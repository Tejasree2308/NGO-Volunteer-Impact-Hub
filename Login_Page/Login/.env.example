# ─── ServiceNow PDI Configuration ───────────────────────────────────────────
# Copy this file to .env and fill in your ServiceNow PDI credentials
# Get your PDI URL from: https://developer.servicenow.com → My Instance
# ─────────────────────────────────────────────────────────────────────────────

VITE_SN_INSTANCE=https://devXXXXXX.service-now.com
VITE_SN_USERNAME=admin
VITE_SN_PASSWORD=your_password_here

VITE_APP_NAME=NGO Impact Hub
VITE_APP_VERSION=1.0.0
